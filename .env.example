# Used by the CLI script `generate_activity_commits.py` only (it loads this file if present).
# The web UI does not load `.env` — configure the server with real environment variables
# (e.g. Railway / Vercel dashboard, or `export` in your shell for local dev).

# Required: start year for the synthetic commit window (Jan 1 → now).
GH_ACTIVITY_YEAR=2022

# Repositories: use one or both. Space- or newline-separated URLs in GH_ACTIVITY_REPOS,
# and/or a file path for GH_ACTIVITY_REPOS_FILE (same format as --repos-file).
GH_ACTIVITY_REPOS=
GH_ACTIVITY_REPOS_FILE=

GH_ACTIVITY_WORK_DIR=
GH_ACTIVITY_BRANCH=
GH_ACTIVITY_COMMITS_PER_REPO=
GH_ACTIVITY_LOG_FILE=
GH_ACTIVITY_SEED=
GH_ACTIVITY_SHALLOW_DEPTH=
GH_ACTIVITY_DRY_RUN=
GH_ACTIVITY_NO_PUSH=

# Optional: identity used by `git commit` if you do not rely on global git config.
# GIT_AUTHOR_NAME=
# GIT_AUTHOR_EMAIL=
